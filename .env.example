# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database (optional for MVP — in-memory fallback if unset)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finassistant

# LLM (required for memo generation)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# SEC EDGAR (required by SEC fair-access policy)
SEC_USER_AGENT=FinAssistant MVP contact@example.com

# News (optional — yfinance used as fallback)
NEWS_API_KEY=
